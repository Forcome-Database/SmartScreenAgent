# Server-only environment for the WP5 HR web workspace (Next.js BFF).
# Copy to `.env.local` for `npm run dev` and fill in real values — never
# commit real secrets. These are also the env vars the `frontend` service in
# the repo-root docker-compose.yml expects.
#
# None of these are exposed to the browser: every var here is read only in
# server code (route handlers, layouts, middleware) under `src/lib/server/`
# and `src/app/api/**`. The browser only ever talks to same-origin
# `/api/proxy/**` and `/api/auth/**`, which forward to FastAPI with the
# session's bearer token attached server-side.

# Base URL of the FastAPI backend this BFF proxies to (server-to-server,
# never sent to the browser).
API_BASE_URL=http://127.0.0.1:8000

# Secret used to HMAC-SHA256-sign the `ssa_session` cookie
# (src/lib/server/session.ts). Any string >= 32 bytes; generate with e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Rotating this secret invalidates all existing sessions.
SESSION_COOKIE_SECRET=replace-with-a-random-32-byte-secret

# DingTalk OAuth app credentials used to build the "使用钉钉登录" authorize
# link (src/app/login/page.tsx) and to complete the login handshake
# (src/app/api/auth/callback/route.ts, which exchanges auth_code with FastAPI's
# POST /auth/dingtalk/login).
DINGTALK_CLIENT_ID=replace-with-dingtalk-app-key
DINGTALK_REDIRECT_URI=http://127.0.0.1:3000/auth/callback

# Optional: override the DingTalk OAuth authorize endpoint. Defaults to
# https://login.dingtalk.com/oauth2/auth if unset.
# DINGTALK_AUTHORIZE_URL=https://login.dingtalk.com/oauth2/auth
